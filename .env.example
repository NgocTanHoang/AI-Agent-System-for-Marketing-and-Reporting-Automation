# Backend / Agent runtime
NVIDIA_NIM_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
# OpenRouter free model override. Default runtime fallback is openai/gpt-oss-120b:free.
OPENROUTER_MODEL_ID=openai/gpt-oss-120b:free
OPENROUTER_MODEL_NAME=gpt-oss-120b (free)
OPENROUTER_MODEL_CONTEXT_WINDOW=131K
WORKER_INSTALL_LOCAL_EMBEDDINGS=false
HEALTHCHECK_REQUIRE_VECTOR_MODULES=false

# Frontend
# Optional frontend API base override. Leave empty to use same-host relative paths or the Vite dev proxy.
VITE_API_BASE_URL=
