FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    MPLBACKEND=Agg

WORKDIR /app

ARG INSTALL_LOCAL_EMBEDDINGS=false

COPY requirements-worker.txt requirements-vector.txt requirements-worker-local-embedding.txt ./

RUN pip install --upgrade pip && \
    pip install -r requirements-worker.txt && \
    if [ "$INSTALL_LOCAL_EMBEDDINGS" = "true" ]; then pip install -r requirements-worker-local-embedding.txt; fi

COPY main.py ./
COPY src ./src
COPY config ./config
COPY infra/healthcheck.py ./infra/healthcheck.py
COPY data/raw/marketing_content ./data/raw/marketing_content

RUN useradd --create-home --shell /bin/bash app && \
    mkdir -p data/processed logs && \
    chown -R app:app /app

USER app

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
  CMD ["python", "infra/healthcheck.py", "--mode", "worker"]

CMD ["python", "main.py"]
